# Database
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-here

# OAuth - GitHub
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend)
RESEND_API_KEY=re_xxxxx
# Use onboarding@resend.dev to test before verifying your own domain.
# Once your domain is verified in Resend, switch to your own address.
EMAIL_FROM=ForMe <onboarding@resend.dev>

# Cloudinary (image hosting)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Mapbox (geocoding & maps)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# App URL (used for redirects, email links, Stripe callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
